{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": { "type": "string", "enum": ["event"] },
    "event": { "type": "string", "enum": ["agent:status", "agent:log", "agent:task", "agent:appearance", "agent:position", "agent:config", "agent:conference", "agent:movement"] },
    "payload": { "type": "object" }
  },
  "required": ["type", "event", "payload"],
  "additionalProperties": true
}
